{
  "annotations": { "list": [] },
  "description": "pfSense Firewall, IDS/IPS, DNS, DHCP Monitoring with Loki",
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["pfsense", "loki", "firewall", "suricata", "haproxy"],
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "browser",
  "title": "pfSense — Güvenlik ve Sistem Logları",
  "uid": "pfsense-loki-v2",
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Loki",
        "multi": false,
        "name": "DS_LOKI",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "📌 Genel Bakış",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Toplam Log (1s)",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({job=\"pfsense\"}[$__range]))",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "🚫 Engellenen (Block)",
      "gridPos": { "h": 4, "w": 5, "x": 4, "y": 1 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "red" } }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({job=\"pfsense\", category=\"firewall\", fw_action=\"block\"}[$__range]))",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "✅ İzin Verilen (Pass)",
      "gridPos": { "h": 4, "w": 5, "x": 9, "y": 1 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({job=\"pfsense\", category=\"firewall\", fw_action=\"pass\"}[$__range]))",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "🟠 Suricata Olayları",
      "gridPos": { "h": 4, "w": 5, "x": 14, "y": 1 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" } }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({job=\"pfsense\", category=\"suricata\"}[$__range]))",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "🟣 pfBlockerNG / DNSBL",
      "gridPos": { "h": 4, "w": 5, "x": 19, "y": 1 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" } }
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum(count_over_time({job=\"pfsense\", category=\"pfblocker\"}[$__range]))",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 101,
      "type": "row",
      "title": "🛡️ Firewall Etkinlikleri",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Log Zaman Çizelgesi: Block vs Pass",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 6 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum", "max"] }
      },
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 15, "lineWidth": 2 } },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": ".*block.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byRegexp", "options": ".*pass.*" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum by (fw_action) (rate({job=\"pfsense\", category=\"firewall\"}[$__rate_interval]))",
          "legendFormat": "{{fw_action}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "piechart",
      "title": "Log Dağılımı (Kategori)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "pieType": "donut"
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "sum by (category) (count_over_time({job=\"pfsense\"}[$__range]))",
          "instant": true,
          "legendFormat": "{{category}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 102,
      "type": "row",
      "title": "🔍 Detaylı Loglar (Son Blocklar ve Uygulamalar)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Son Engellenen Bağlantılar (Firewall)",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": {
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{job=\"pfsense\", category=\"firewall\", fw_action=\"block\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "logs",
      "title": "Suricata ve pfBlockerNG Detayları",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{job=\"pfsense\", category=~\"suricata|pfblocker\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 103,
      "type": "row",
      "title": "📋 Canlı Log Akışı",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "collapsed": false
    },
    {
      "id": 10,
      "type": "logs",
      "title": "Tüm pfSense Trafiği",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 26 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{job=\"pfsense\"}",
          "refId": "A"
        }
      ]
    }
  ]
}
