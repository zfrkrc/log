      "targets": [{ "datasource": { "type": "loki", "uid": "${DS_LOKI}" }, "expr": "sum(count_over_time({job=\"pfsense\", category=\"firewall\", fw_action=\"block\"}[$__range]))", "instant": true, "refId": "A" }]
