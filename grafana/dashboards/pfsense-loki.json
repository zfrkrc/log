      "options": { "legend": { "displayMode": "table", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 15, "lineWidth": 2 } }, "overrides": [ { "matcher": { "id": "byRegexp", "options": ".*block.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }, { "matcher": { "id": "byRegexp", "options": ".*pass.*" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] } ] },
      "targets": [{ "datasource": { "type": "loki", "uid": "${DS_LOKI}" }, "expr": "sum by (fw_action) (rate({job=\"pfsense\", category=\"firewall\"}[$__rate_interval]))", "legendFormat": "{{fw_action}}", "refId": "A" }]
