    {
      "id": 1,
      "type": "stat",
      "title": "Toplam Log",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "textMode": "auto" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "dark-blue" } } },
      "targets": [{ "datasource": { "type": "loki", "uid": "${DS_LOKI}" }, "expr": "sum(count_over_time({job=\"pfsense\"}[$__range]))", "instant": true, "refId": "A" }]
    },
